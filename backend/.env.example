# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Server Configuration
PORT=3000

# Optional live route data
# Used to fetch distance for any city/station pair.
DISTANCE_MATRIX_API_KEY=your_distance_matrix_api_key_here

# Used to fetch train options when source/destination station codes are known.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_RAIL_HOST=indian-railway-api.p.rapidapi.com

# Notes:
# 1. Get GEMINI_API_KEY from: https://aistudio.google.com/apikey
# 2. The smart train assistant will work with this key
# 3. DISTANCE_MATRIX_API_KEY enables live road distance lookup
# 4. RAPIDAPI_KEY enables live train lookup through RapidAPI
# 5. Without DISTANCE_MATRIX_API_KEY, the app estimates distance from OpenStreetMap geocoding
# 6. Without RAPIDAPI_KEY, the app shows local/demo trains or asks users to check IRCTC/NTES
